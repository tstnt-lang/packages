use thread

do animate(msg: str, times: int) {
    let mut i = 0
    while i < times {
        let dots = strings.repeat(".", (i % 3) + 1)
        let spaces = strings.repeat(" ", 3 - len(dots))
        print_no_ln("\r" + msg + dots + spaces)
        thread.sleep(400)
        i += 1
    }
    print("\r" + msg + "... done")
}
do once(msg: str) {
    print_no_ln(msg + "...")
}
do done() {
    print(" ✓")
}
